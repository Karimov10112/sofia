# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sofia-shop

# JWT
JWT_SECRET=sofia_shop_jwt_secret_change_in_production
JWT_EXPIRES_IN=30m

# Google OAuth
# Google Console: https://console.developers.google.com
# 1. Create project
# 2. Enable "Google+ API" or "Google Identity"
# 3. Create OAuth 2.0 credentials
# 4. Add redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL (for redirects after OAuth)
FRONTEND_URL=http://localhost:5173

# Email (NodeMailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
